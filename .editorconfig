# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# The default behavior for all files
[*]
charset = utf-8
end_of_line = lf
trim_trailing_whitespace = true
insert_final_newline = true

# Exclude binary files from EditorConfig formatting
[*.{png,jpg,jpeg,gif,ico,webp,bmp,tif,tiff,mp3,mp4,avi,mov,webm,wav,ogg,pdf,doc,docx,xls,xlsx,ppt,pptx,zip,tar,gz,rar,7z,exe,dll,so,dylib,class,o,a,lib,bin,ttf,otf,woff,woff2,eot,sqlite,db}]
end_of_line = unset
trim_trailing_whitespace = unset
insert_final_newline = unset
charset = unset

# Batch files might need CRLF in Windows Command Prompt
[*.{bat,cmd}]
end_of_line = crlf

[*.md]
insert_final_newline = false
trim_trailing_whitespace = false

[*.{js,jsx,json,ts,tsx,yml,yaml}]
indent_size = 2
indent_style = space
max_line_length = 80
