# Security: quarantine newly published packages for 7 days (npm 11.10.0+)
min-release-age=7

# Asphaltos: route @neozen packages to local Verdaccio registry (AZ-1454)
@neozen:registry=https://OMENTARA:4873
audit=false
# AZ-1868: exempt our own @neozen/* from the min-release-age cooldown — we own every release
min-release-age-exclude=@neozen/*
